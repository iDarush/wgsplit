# Copy to /etc/splitvpn/splitvpn.env and edit for the VPS.

# Interfaces.
WG_IN_IF="wg1"
WG_OUT_IF="wg0"
WAN_IF="dev0"

# Optional WireGuard config bootstrap. ensure-wireguard-configs.sh/apply.sh
# create wg0/wg1 only when the target config file does not already exist.
WIREGUARD_DIR="/etc/wireguard"

# wg0: RU as a client of the FI WireGuard server. WG0_PRIVATE_KEY must match
# the RU peer public key configured on FI.
WG0_ADDRESS="10.30.0.3/32"
WG0_PRIVATE_KEY=""
WG0_PEER_PUBLIC_KEY=""
WG0_ENDPOINT="116.202.97.35:51820"
WG0_ALLOWED_IPS="0.0.0.0/0"
WG0_TABLE="off"
WG0_MTU="1420"
WG0_PERSISTENT_KEEPALIVE="25"

# wg1: local server for end-user clients. If WG1_PRIVATE_KEY is empty and
# wg1.conf is absent, ensure-wireguard-configs.sh generates a new key.
WG1_ADDRESS="10.40.0.1/24"
WG1_PRIVATE_KEY=""
WG1_LISTEN_PORT="51821"
WG1_MTU="1420"

# Address on WG_IN_IF that clients should use as DNS.
DNS_LISTEN_ADDRESS="10.40.0.1"

# DNS upstreams. apply.sh pins these /32 routes to WG_OUT_IF.
DNS_UPSTREAMS="1.1.1.1 9.9.9.9"

# DNS answer set backend:
# - auto: use nftset when dnsmasq supports it, otherwise ipset.
# - nftset: require dnsmasq compiled with HAVE_NFTSET.
# - ipset: compatible with Ubuntu 22.04 dnsmasq packages.
DNS_SET_BACKEND="auto"
IPSET_DOMAIN_SET="splitvpn_ru_domain_v4"
IPSET_FORCE_RU_SET="splitvpn_force_ru_v4"
IPSET_FORCE_FI_SET="splitvpn_force_fi_v4"

# Manual override lists. Lines may contain domains, wildcard domains, IPv4
# addresses, IPv4 CIDRs, blank lines, and comments starting with #.
FORCE_RU_FILE="/etc/splitvpn/force-ru.txt"
FORCE_FI_FILE="/etc/splitvpn/force-fi.txt"

# Force client UDP/TCP 53 to local dnsmasq. Does not affect DoH/DoT.
FORCE_CLIENT_DNS="1"

# Policy routing table IDs and names.
RU_TABLE_ID="100"
RU_TABLE_NAME="split_ru_direct"
WG_TABLE_ID="101"
WG_TABLE_NAME="split_wg_out"

# Marks used by nftables and ip rule.
RU_MARK="0x10"
WG_MARK="0x20"
RU_RULE_PRIORITY="100"
WG_RULE_PRIORITY="101"

# Direct RU path. If WAN_GATEWAY is empty, apply.sh tries:
# ip -4 route show default dev "$WAN_IF"
WAN_GATEWAY=""

# WG egress route. Empty means "default dev WG_OUT_IF".
# Set WG_GATEWAY only if your wg0 routing requires a next-hop address.
WG_GATEWAY=""

# RU GeoIP source. ipdeny is simple country-CIDR data; replace if preferred.
RU_ZONE_URL="https://www.ipdeny.com/ipblocks/data/countries/ru.zone"

# Generated runtime files.
ETC_DIR="/etc/splitvpn"
GENERATED_DIR="/etc/splitvpn/generated"
NFT_CONF="/etc/splitvpn/generated/splitvpn.nft"
GEOIP_NFT_CONF="/etc/splitvpn/generated/ru-geoip-v4.nft"
MANUAL_NFT_CONF="/etc/splitvpn/generated/manual-rules.nft"
DNSMASQ_CONF="/etc/dnsmasq.d/splitvpn.conf"
